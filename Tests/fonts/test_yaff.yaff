# Test YAFF font for Pillow test suite.
# Contains a small set of ASCII glyphs with kerning.

name: Test Font 8px
family: Test
spacing: proportional
ascent: 7
descent: 2

default-char: 0x3f

u+0020:
'A':
    .......
    .......
    .......
    .......
    .......
    .......
    .......
    .......
    .......

    left-bearing: 0
    right-bearing: 0
    shift-up: -2

u+0041:
    .......
    .......
    .@@@@..
    @....@.
    @@@@@@.
    @....@.
    @....@.
    .......
    .......

    left-bearing: 0
    right-bearing: 0
    shift-up: -2
    right-kerning:
        u+0056 -2
        u+0054 -1

u+0056:
    .......
    .......
    @....@.
    @....@.
    @....@.
    .@..@..
    ..@@...
    .......
    .......

    left-bearing: 0
    right-bearing: 0
    shift-up: -2
    left-kerning:
        u+0041 -1

u+0054:
    ........
    ........
    @@@@@@@@
    ...@@...
    ...@@...
    ...@@...
    ...@@...
    ........
    ........

    left-bearing: 0
    right-bearing: 0
    shift-up: -2

u+002e:
    ...
    ...
    ...
    ...
    ...
    ...
    .@.
    ...
    ...

    left-bearing: 0
    right-bearing: 0
    shift-up: -2

u+003f:
    .......
    .......
    .@@@@..
    @....@.
    ..@@@..
    .......
    ..@....
    .......
    .......

    left-bearing: 0
    right-bearing: 0
    shift-up: -2
